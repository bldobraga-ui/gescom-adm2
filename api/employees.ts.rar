export default function handler(req, res) {
  if (req.method === "POST") {
    const data = req.body;

    return res.status(200).json({
      message: "Funcionário recebido com sucesso",
      data,
    });
  }

  if (req.method === "GET") {
    return res.status(200).json([]);
  }

  return res.status(405).json({ message: "Método não permitido" });
}